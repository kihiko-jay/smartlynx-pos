# ── Local branch database (READ/WRITE only inside the branch LAN) ───────────────────
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432
LOCAL_DB_NAME=smartlynx_db
LOCAL_DB_USER=smartlynx
LOCAL_DB_PASS=smartlynx_pass

# ── Central cloud backend API ───────────────────────────────────────────────────────
CLOUD_API_URL=https://api.yourdomain.com/api/v1
CLOUD_API_KEY=CHANGE_ME_sync_agent_cloud_key
API_BASE_URL=http://localhost:8000
SYNC_AGENT_API_KEY=CHANGE_ME_generate_with_openssl_rand_-hex_32

# ── Branch identity / topology ──────────────────────────────────────────────────────
DEPLOYMENT_MODE=multi_branch
NODE_ROLE=store_server
STORE_ID=1
BRANCH_CODE=CBD001
BRANCH_NAME=Nairobi CBD
TERMINAL_ID=T01
ENABLE_HQ_SYNC=true
STORE_SERVER_HOST=192.168.1.10

# ── Polling intervals (seconds) ─────────────────────────────────────────────────────
SYNC_INTERVAL_PRODUCTS=60
SYNC_INTERVAL_CUSTOMERS=60
SYNC_INTERVAL_TRANSACTIONS=10
SYNC_INTERVAL_EMPLOYEES=300
SYNC_INTERVAL=5000

# ── Batch sizes ──────────────────────────────────────────────────────────────────────
BATCH_SIZE=500

# ── Logging ──────────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/sync-agent.log

# ── Checkpoint storage ───────────────────────────────────────────────────────────────
# Defaults to /app/data/checkpoints.json inside the mounted data volume.
# CHECKPOINT_DIR=/app/data
