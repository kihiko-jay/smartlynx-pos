{
  "name": "smartlynx-sync-agent",
  "version": "4.5.1",
  "description": "Smartlynx local sync agent \u2014 bridges branch-local store data to the central cloud backend",
  "engines": {
    "node": ">=18"
  },
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "node --test tests/sync-agent.test.js",
    "test:watch": "node --test --watch tests/sync-agent.test.js",
    "pm2:start": "pm2 start src/index.js --name smartlynx-sync --time",
    "pm2:stop": "pm2 stop smartlynx-sync",
    "pm2:restart": "pm2 restart smartlynx-sync",
    "pm2:logs": "pm2 logs smartlynx-sync"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "axios-retry": "^4.4.0",
    "better-queue": "^3.8.12",
    "node-cron": "^3.0.3",
    "pg": "^8.12.0",
    "winston": "^3.13.0",
    "dotenv": "^16.4.5",
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
